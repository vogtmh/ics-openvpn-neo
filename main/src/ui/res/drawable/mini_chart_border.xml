<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Background color -->
    <solid android:color="#1a1a1a" />
    
    <!-- Rounded border -->
    <stroke
        android:width="2dp"
        android:color="@color/accent" />
    
    <!-- Corner radius for rounded corners -->
    <corners android:radius="8dp" />
    
</shape>
