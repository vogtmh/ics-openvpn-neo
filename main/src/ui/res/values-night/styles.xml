<resources>

    <style name="blinkt.baseTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">#000000</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#9718EC</item>
        <item name="alertDialogTheme">@style/blinkt.alertDialog</item>
        <item name="preferenceTheme">@style/blinkt.preferenceTheme</item>

        <item name="android:navigationBarColor">
            @android:color/black
        </item>

        <!-- Optional: set to transparent if your app is drawing behind the status bar. -->
        <item name="android:statusBarColor">
            @android:color/black
        </item>

        <!-- Optional: set for a light status bar with dark content. -->
        <item name="android:windowLightStatusBar">
            false
        </item>
        
        <!-- Force #111111 background in dark mode -->
        <item name="android:colorBackground">#111111</item>
        <item name="android:windowBackground">#111111</item>
        
        <!-- Force #252525 background for popup dialogs/menus -->
        <item name="colorBackgroundFloating">#252525</item>
        <item name="android:colorBackgroundFloating">#252525</item>
    </style>

    <style name="blinkt.dialog" parent="Theme.AppCompat.DayNight.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="alertDialogTheme">@style/blinkt.alertDialog</item>
        <!-- Force #252525 background in dark mode for dialogs -->
        <item name="android:colorBackground">#252525</item>
        <item name="android:windowBackground">#252525</item>
        
        <item name="colorBackgroundFloating">#252525</item>
        <item name="android:colorBackgroundFloating">#252525</item>
        
        <!-- Force black status bar for dialog activities -->
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="blinkt.alertDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <!-- Force #333333 background for all dialogs -->
        <item name="android:colorBackground">#333333</item>
        <item name="android:windowBackground">#333333</item>
        
        <item name="colorBackgroundFloating">#333333</item>
        <item name="android:colorBackgroundFloating">#333333</item>
    </style>

    <!-- Custom preference theme to remove default padding -->
    <style name="blinkt.preferenceTheme" parent="PreferenceThemeOverlay.v14.Material">
        <item name="preferenceScreenStyle">@style/blinkt.preferenceScreen</item>
        <item name="preferenceCategoryStyle">@style/blinkt.preferenceCategory</item>
        <item name="preferenceStyle">@style/blinkt.preference</item>
        <item name="checkBoxPreferenceStyle">@style/blinkt.checkBoxPreference</item>
        <item name="preferenceInformationStyle">@style/blinkt.preference</item>
        <item name="dialogPreferenceStyle">@style/blinkt.preference</item>
        <item name="editTextPreferenceStyle">@style/blinkt.editTextPreference</item>
    </style>

    <style name="blinkt.preferenceScreen" parent="Preference.PreferenceScreen">
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
    </style>
    
    <style name="blinkt.preferenceCategory" parent="Preference.Category">
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="blinkt.preference" parent="Preference">
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:layout_marginLeft">0dp</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:titleTextAppearance">@style/blinkt.preferenceTitle</item>
    </style>
    
    <style name="blinkt.checkBoxPreference" parent="Preference.CheckBoxPreference">
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:layout_marginLeft">0dp</item>
        <item name="android:layout_marginStart">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:titleTextAppearance">@style/blinkt.preferenceTitle</item>
    </style>
    
    <style name="blinkt.preferenceTitle" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
    </style>

</resources>
